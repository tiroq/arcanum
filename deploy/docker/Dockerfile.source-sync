FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -o /bin/source-sync ./cmd/source-sync

FROM alpine:3.19
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /bin/source-sync /bin/source-sync
EXPOSE 8081
ENTRYPOINT ["/bin/source-sync"]
