# Runeforge Platform - Environment Variables Example
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_DSN=postgres://runeforge:changeme@localhost:5432/runeforge?sslmode=disable
DATABASE_MAX_CONNS=25

# ─── NATS ────────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222
NATS_STREAM_PREFIX=runeforge

# ─── HTTP Server ─────────────────────────────────────────────────────────────
HTTP_PORT=8080
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=30s
HTTP_SHUTDOWN_TIMEOUT=15s

# ─── Auth ────────────────────────────────────────────────────────────────────
ADMIN_TOKEN=change-me-in-production

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ─── AI Providers ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=60

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT_SECONDS=60

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=120

# ─── Ollama: Legacy single-model config (simple) ────────────────────────────
# Each role falls back to OLLAMA_DEFAULT_MODEL when unset.
OLLAMA_FAST_MODEL=
OLLAMA_FAST_TIMEOUT_SECONDS=
OLLAMA_PLANNER_MODEL=
OLLAMA_PLANNER_TIMEOUT_SECONDS=
OLLAMA_REVIEW_MODEL=

# ─── Ollama: Execution Profiles (advanced) ───────────────────────────────────
# Profiles override _MODEL vars when set. DSL format:
#   model?param=value&param=value|model2?param=value
#
# Candidates separated by "|", params start with "?" and separated by "&".
# Supported params: think (on/off/thinking/nothinking), timeout (seconds), json (true/false)
#
# Resolution priority per role: _PROFILE > _MODEL > OLLAMA_DEFAULT_MODEL
#
# Examples:
#   Single model with thinking:    qwen2.5:7b-instruct?think=on
#   Fallback chain:                qwen2.5:7b-instruct?think=on&timeout=240|llama3.2:3b?think=off&timeout=60
#   JSON output:                   qwen2.5:7b-instruct?json=true&timeout=120|llama3.2:3b?json=true
#
OLLAMA_DEFAULT_PROFILE=
OLLAMA_FAST_PROFILE=
OLLAMA_PLANNER_PROFILE=
OLLAMA_REVIEW_PROFILE=

# ─── Feature Flags ───────────────────────────────────────────────────────────
FEATURE_AUTO_APPROVE=false
FEATURE_WRITEBACK_ENABLED=false

# ─── Retry ───────────────────────────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_MULTIPLIER=2.0
RETRY_INITIAL_INTERVAL_SECONDS=5

# ─── Google Tasks ────────────────────────────────────────────────────────────
GOOGLE_TASKS_CREDENTIALS_PATH=
GOOGLE_TASKS_POLL_INTERVAL_SECONDS=300
